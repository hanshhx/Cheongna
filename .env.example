# ─────────────────────────────────────────────
# 청라 SK V1 환경변수 — 실제 값은 .env.local 에 (깃에 안 올라감)
# ─────────────────────────────────────────────

# 운영 도메인 (sitemap.xml / OG / canonical 에 사용)
NEXT_PUBLIC_SITE_URL=https://cnskv1.com

# web3forms 액세스 키 — 폼 제출용
# 발급: https://web3forms.com (무료, 도메인 화이트리스트로 보호)
NEXT_PUBLIC_WEB3FORMS_KEY=

# GA4 측정 ID — 예: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# 네이버 검색광고 전환 스크립트 사이트 ID (광고 → 폼/전화 전환 추적)
NEXT_PUBLIC_NAVER_WCS_ID=

# 검색엔진 사이트 인증 메타 코드
NEXT_PUBLIC_NAVER_VERIFY=
NEXT_PUBLIC_GOOGLE_VERIFY=

# 카카오 채널 ID (예: _xxxxxx) — 추후 채널 버튼 추가 시 사용
NEXT_PUBLIC_KAKAO_CHANNEL=
